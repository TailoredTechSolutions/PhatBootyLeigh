{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "border-glow.js",
              "components/**",
              "dashboard/**",
              "galaxy-bg.js"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Playfair Display|DM Sans|Inter|JetBrains Mono|DM Mono))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Playfair Display, DM Sans, Inter, JetBrains Mono, DM Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|solid|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, solid, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|rose|success|warning|danger|neutral)$/]",
        "message": "<Badge> tone must be one of 'gold' | 'rose' | 'success' | 'warning' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BorderGlow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|className|edgeSensitivity|glowColor|backgroundColor|borderRadius|glowRadius|glowIntensity|coneSpread|fillOpacity|animated|colors|key|ref|className|style|children)$/]",
        "message": "<BorderGlow> doesn't accept that prop. Declared props: children, className, edgeSensitivity, glowColor, backgroundColor, borderRadius, glowRadius, glowIntensity, coneSpread, fillOpacity, animated, colors."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|disabled|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, disabled, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|action|padding|hover|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, eyebrow, action, padding, hover, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GigCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|client|date|venue|fee|status|thumbnail|glow|onClick|key|ref|className|style|children)$/]",
        "message": "<GigCard> doesn't accept that prop. Declared props: title, client, date, venue, fee, status, thumbnail, glow, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='GigCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:confirmed|pending|inquiry|completed)$/]",
        "message": "<GigCard> status must be one of 'confirmed' | 'pending' | 'inquiry' | 'completed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|prefix|suffix|delta|icon|accent|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, prefix, suffix, delta, icon, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|rose|success|neutral)$/]",
        "message": "<KpiCard> accent must be one of 'gold' | 'rose' | 'success' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|showPercent|tone|height|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, label, showPercent, tone, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|rose|success)$/]",
        "message": "<ProgressBar> tone must be one of 'gold' | 'rose' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|rule|align|key|ref|className|style|children)$/]",
        "message": "<SectionTitle> doesn't accept that prop. Declared props: eyebrow, title, rule, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionTitle> align must be one of 'left' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
